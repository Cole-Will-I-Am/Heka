[Unit]
Description=Heka — Autonomous Self-Evolving Agent System
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
WorkingDirectory=/opt/heka
ExecStart=/usr/bin/python3 main.py
Restart=always
RestartSec=30
WatchdogSec=900
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
